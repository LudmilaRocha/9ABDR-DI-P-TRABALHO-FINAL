# =========================
# Arquivos de Dados (CRÍTICO)
# =========================
# Ignorar a pasta de dados inteira (RAW, BRONZE, SILVER, GOLD)
# Nunca faça commit de grandes volumes de dados (Parquet, JSON, TXT, CSV)
data/
*.parquet
*.json
*.txt
*.csv
*.zip

# =========================
# Arquivos de Ambientes Locais / Docker
# =========================
docker-compose.yml
.ipynb_checkpoints/
__pycache__/
*.py[cod]
*$py.class
*.so

# Ambientes Virtuais
venv/
.venv/
env/
.env

# =========================
# Terraform (IaC)
# =========================
