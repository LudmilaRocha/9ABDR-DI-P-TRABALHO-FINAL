# Copie para .env e preencha. Nao versionar o .env.

# Account identifier sem https:// e sem .snowflakecomputing.com
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=

# PAT (recomendado) ou senha
SNOWFLAKE_PAT=
SNOWFLAKE_PASSWORD=

SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_DATABASE=DI_P_MEDALLION
SNOWFLAKE_WAREHOUSE=WH_DI_P_PIPELINE
SNOWFLAKE_SCHEMA=SILVER

DBT_THREADS=4
OPENFOOTBALL_SEASON=2023-24
DATA_FLAT_DIR=data_flat
