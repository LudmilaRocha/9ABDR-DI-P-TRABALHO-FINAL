# EXEMPLO: Infraestrutura nativa no Google Cloud (GCP) para Arquitetura Medalhão
# Este arquivo é apenas demonstrativo e não será executado por padrão.

provider "google" {
  project = "meu-projeto-gcp-football"
  region  = "us-central1"
}

# 1. Armazenamento Físico (Google Cloud Storage)
resource "google_storage_bucket" "bronze" {
  name     = "meu-projeto-datalake-bronze"
  location = "US"
}
resource "google_storage_bucket" "silver" {
  name     = "meu-projeto-datalake-silver"
  location = "US"
}
resource "google_storage_bucket" "gold" {
  name     = "meu-projeto-datalake-gold"
  location = "US"
}

# 2. Catálogo e Data Warehouse (BigQuery Datasets)
# Equivalente aos Schemas do Unity Catalog
resource "google_bigquery_dataset" "bronze" {
  dataset_id  = "bronze"
  description = "Camada Bronze: Dados brutos"
  location    = "US"
}
resource "google_bigquery_dataset" "silver" {
  dataset_id  = "silver"
  description = "Camada Silver: Dados limpos e enriquecidos"
  location    = "US"
}
resource "google_bigquery_dataset" "gold" {
  dataset_id  = "gold"
  description = "Camada Gold: Agregações de negócio"
  location    = "US"
}
