# EXEMPLO: Infraestrutura nativa na AWS para Arquitetura Medalhão
# Este arquivo é apenas demonstrativo e não será executado por padrão.

provider "aws" {
  region = "us-east-1"
}

# 1. Armazenamento Físico (Data Lake em Amazon S3)
resource "aws_s3_bucket" "bronze" { 
  bucket = "meu-projeto-datalake-bronze" 
}
resource "aws_s3_bucket" "silver" { 
  bucket = "meu-projeto-datalake-silver" 
}
resource "aws_s3_bucket" "gold" { 
  bucket = "meu-projeto-datalake-gold" 
}

# 2. Catálogo de Dados e Metastore (AWS Glue Data Catalog)
# Equivalente aos Schemas do Unity Catalog no Databricks
resource "aws_glue_catalog_database" "bronze" { 
  name = "bronze" 
  description = "Camada Bronze: Dados brutos"
}
resource "aws_glue_catalog_database" "silver" { 
  name = "silver" 
  description = "Camada Silver: Dados limpos e enriquecidos"
}
resource "aws_glue_catalog_database" "gold" { 
  name = "gold" 
  description = "Camada Gold: Agregações de negócio"
}
